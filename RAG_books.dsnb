        "hasTitle" : false,
        "message" : [
          "%script",
          "-- test connectivity to GenAI Service",
          "set SERVEROUTPUT on;",
          "declare",
          "    l_response dbms_cloud_types.resp;",
          "    l_body clob;",
          "    l_blob blob;",
          "begin",
          "    l_body := to_clob( ",
          "     '{",
          "        \"compartmentId\": \"ocid1.tenancy.oc1..aaaaaaaaiyavtwbz4kyu7g7b6wglllccbflmjx2lzk5nwpbme44mv54xu7dq\",",
          "\t\t\"chatRequest\":{",
          "\t\t\t  \"apiFormat\":\"GENERIC\",",
          "\t\t\t  \"messages\":[",
          "\t\t\t\t {",
          "\t\t\t\t\t\"role\":\"USER\",",
          "\t\t\t\t\t\"content\":[",
          "\t\t\t\t\t   {",
          "\t\t\t\t\t\t  \"type\":\"TEXT\",",
          "\t\t\t\t\t\t  \"text\":\"In two sentences, explain what Oracle OCI is\"",
          "\t\t\t\t\t   }",
          "\t\t\t\t\t]",
          "\t\t\t\t }",
          "\t\t\t  ],",
          "\t\t\t  \"maxTokens\":700,",
          "\t\t\t  \"temperature\":0,",
          "\t\t\t  \"numGenerations\":1,",
          "\t\t\t  \"topK\":-1,",
          "\t\t\t  \"isStream\":false",
          "\t\t   },",
          "\t\t   \"servingMode\":{",
          "\t\t\t  \"servingType\":\"ON_DEMAND\",",
          "\t\t\t  \"modelId\":\"meta.llama-3.1-70b-instruct\"",
          "\t\t   }",
          "    }');",
          "",
          "    l_blob := apex_util.clob_to_blob(p_clob => l_body,p_charset => 'AL32UTF8');",
          "    l_response := dbms_cloud.send_request(",
          "        credential_name => 'RAG_CREDENTIAL',",
          "        uri => 'https://inference.generativeai.us-chicago-1.oci.oraclecloud.com/20231130/actions/chat',",
          "        method => dbms_cloud.method_post,",
          "        body => l_blob",
          "    );",
          "\tdbms_output.put_line('Status Code: ' || dbms_cloud.get_response_status_code(l_response));",
          "    dbms_output.put_line('Text: ' || dbms_cloud.get_response_text(l_response));",
          "end;"
        ],
        "selectedVisualization" : "raw",
