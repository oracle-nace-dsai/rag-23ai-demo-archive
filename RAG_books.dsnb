          "results" : [
            {
              "message" : "\n---------------------------\nStatus Code: 200\nText:\n{\"modelId\":\"meta.llama-3.1-70b-instruct\",\"modelVersion\":\"1.0.0\",\"chatResponse\":{\n\"apiFormat\":\"GENERIC\",\"timeCreated\":\"2025-04-08T20:40:29.029Z\",\"choices\":[{\"inde\nx\":0,\"message\":{\"role\":\"ASSISTANT\",\"content\":[{\"type\":\"TEXT\",\"text\":\"Oracle\nCloud Infrastructure (OCI) is a comprehensive cloud platform that provides a\nwide range of services, including computing, storage, networking, and database\nmanagement, to support the deployment and management of applications and\nworkloads in the cloud. OCI offers a secure, scalable, and highly available\ninfrastructure that allows users to build, deploy, and manage modern\napplications and services, while also providing a range of tools and services to\nsupport migration, integration, and management of existing on-premises\nworkloads.\"}],\"toolCalls\":[]},\"finishReason\":\"stop\",\"logprobs\":{}}],\"usage\":{\"co\nmpletionTokens\":98,\"promptTokens\":44,\"totalTokens\":142}}}\n\n\nPL/SQL procedure successfully completed.\n\n",
              "type" : "TEXT"
            }
          ],
          "forms" : "[]"
