        "message" : [
          "%script",
          "-- create credential that ADW uses to talk to ObjStore and GenAI services",
          "-- pem key pair and fingerprint are created in cloud shell and stored in ~/.oci",
          "-- this will require OCI developer account, OCIDS, and that OCI developer will need access to APEX developer account",
          "-- admin user must grant execute on DBMS_CLOUD to <db-developer>; grant execute on DBMS_CLOUD_AI to <db-developer>;",
          "BEGIN DBMS_CLOUD.DROP_CREDENTIAL('RAG_CREDENTIAL'); EXCEPTION WHEN OTHERS THEN NULL; END;",
          "/",
          "BEGIN",
          "   DBMS_CLOUD.CREATE_CREDENTIAL (",
          "       credential_name => 'RAG_CREDENTIAL',",
          "       user_ocid       => 'ocid1.user.oc1..aaaaaaaafolzomxi6tqsoy6wdnlwj2hxv4ooljhtvfgy4sm722iwxaakgqqq',",
          "       tenancy_ocid    => 'ocid1.tenancy.oc1..aaaaaaaaiyavtwbz4kyu7g7b6wglllccbflmjx2lzk5nwpbme44mv54xu7dq',",
          "       private_key     => '",
          "-----BEGIN PRIVATE KEY-----",
          "MIIEvQIBADANBgkqhkiG9w0BAQEFAASCBKcwggSjAgEAAoIBAQC+5pZKurggk5aG",
          "z60xAk/cx855jjeHmM6y86fjnMOQC6C7OKibloJh+WecIxPihOSiBrr/rYaMqOW0",
